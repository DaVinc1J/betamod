{
  "multipart": [
    { "apply": { "model": "betamod:block/copper_wire_core" } },
    { "when": { "north": "true" }, "apply": { "model": "betamod:block/copper_wire_arm" } },
    { "when": { "east":  "true" }, "apply": { "model": "betamod:block/copper_wire_arm", "y": 90,  "uvlock": true } },
    { "when": { "south": "true" }, "apply": { "model": "betamod:block/copper_wire_arm", "y": 180, "uvlock": true } },
    { "when": { "west":  "true" }, "apply": { "model": "betamod:block/copper_wire_arm", "y": 270, "uvlock": true } },
    { "when": { "up":    "true" }, "apply": { "model": "betamod:block/copper_wire_arm", "x": 270, "uvlock": true } },
    { "when": { "down":  "true" }, "apply": { "model": "betamod:block/copper_wire_arm", "x": 90,  "uvlock": true } }
  ]
}
